#!/usr/bin/env bash
# Devcontainer: launch Aisets API + Vite frontend.
# Usage:
#   ui
#   ui /workspace/project-a /workspace/project-b
#   ui --app /workspace/project-a
#   ui --no-open
#   ui stop
set -euo pipefail

PORT="${AISETS_PORT:-19520}"
VITE_PORT="${AISETS_UI_PORT:-5174}"
OPEN_MODE=browser
PIDDIR=/tmp/aisets-dev-servers
LOGDIR=/tmp
mkdir -p "$PIDDIR"

PNPM_BIN=""
if command -v pnpm >/dev/null 2>&1; then
  PNPM_BIN="$(command -v pnpm)"
elif [ -x /usr/local/bin/pnpm ]; then
  PNPM_BIN="/usr/local/bin/pnpm"
fi

is_port_open() {
  timeout 1 bash -c "echo > /dev/tcp/127.0.0.1/$1" 2>/dev/null
}

open_browser() {
  local url="$1"
  if command -v xdg-open >/dev/null 2>&1; then
    xdg-open "$url" >/dev/null 2>&1 &
    return 0
  fi
  return 1
}

open_app_window() {
  local url="$1"
  local browser
  for browser in google-chrome google-chrome-stable chromium chromium-browser microsoft-edge brave-browser; do
    if command -v "$browser" >/dev/null 2>&1; then
      "$browser" "--app=$url" >/dev/null 2>&1 &
      return 0
    fi
  done
  return 1
}

open_ui() {
  local url="$1"
  case "$OPEN_MODE" in
    none)
      return 0
      ;;
    app)
      if open_app_window "$url"; then
        return 0
      fi
      if open_browser "$url"; then
        echo "  opener       app launcher unavailable; opened browser instead"
        return 0
      fi
      echo "  opener       unavailable in this devcontainer; open the URL on the host"
      ;;
    browser)
      if ! open_browser "$url"; then
        echo "  opener       unavailable in this devcontainer; open the URL on the host"
      fi
      ;;
  esac
}

pids_on_port() {
  local port="$1"
  local hex_port
  hex_port=$(printf '%04X' "$port")
  local inodes=""
  while read -r _ local_addr _ state _ _ _ _ _ inode _; do
    if [ "$state" = "0A" ] && [[ "$local_addr" == *":$hex_port" ]]; then
      inodes="$inodes $inode"
    fi
  done < /proc/net/tcp6 2>/dev/null
  [ -z "$inodes" ] && return
  for pid_dir in /proc/[0-9]*/fd; do
    local pid="${pid_dir#/proc/}"
    pid="${pid%/fd}"
    for fd in "$pid_dir"/*; do
      local target
      target=$(readlink "$fd" 2>/dev/null) || continue
      for ino in $inodes; do
        if [[ "$target" == *"socket:[$ino]"* ]]; then
          echo "$pid"
        fi
      done
    done
  done 2>/dev/null | sort -u
}

kill_port() {
  local port="$1"
  local pids
  pids=$(pids_on_port "$port" || true)
  [ -z "$pids" ] && return
  for pid in $pids; do kill "$pid" 2>/dev/null || true; done
  sleep 0.3
  for pid in $pids; do kill -9 "$pid" 2>/dev/null || true; done
}

kill_pid_file() {
  local pf="$1"
  [ -f "$pf" ] || return 0
  local pid
  pid=$(cat "$pf")
  pkill -P "$pid" 2>/dev/null || true
  kill "$pid" 2>/dev/null || true
  sleep 0.3
  kill -9 "$pid" 2>/dev/null || true
  rm -f "$pf"
}

if [ "${1:-}" = "stop" ]; then
  kill_pid_file "$PIDDIR/api.pid"
  pkill -f 'aisets.* ui' 2>/dev/null || true
  kill_port "$PORT"
  kill_pid_file "$PIDDIR/vite.pid"
  kill_port "$VITE_PORT"
  echo "  api + vite stopped"
  exit 0
fi

api_args=()
for arg in "$@"; do
  case "$arg" in
    --app)
      OPEN_MODE=app
      ;;
    --no-open)
      OPEN_MODE=none
      ;;
    *)
      api_args+=("$arg")
      ;;
  esac
done

kill_pid_file "$PIDDIR/api.pid"
pkill -f 'aisets.* ui' 2>/dev/null || true
kill_port "$PORT"

export AISETS_UI_HOST=0.0.0.0
AISETS_UI_FLAGS="--port ${PORT}"
for arg in "${api_args[@]}"; do
  printf -v quoted_arg '%q' "$arg"
  AISETS_UI_FLAGS+=" $quoted_arg"
done
export AISETS_UI_FLAGS

AIR_BIN=""
for p in "$(go env GOPATH)/bin/air" /go/bin/air /usr/local/go/bin/air; do
  [ -x "$p" ] && AIR_BIN="$p" && break
done
if [ -z "$AIR_BIN" ]; then
  echo "  air          not found - installing..." >&2
  go install github.com/air-verse/air@latest
  AIR_BIN="$(go env GOPATH)/bin/air"
fi

nohup "$AIR_BIN" -c /workspace/.air.toml > "$LOGDIR/aisets-api-dev.log" 2>&1 &
echo $! > "$PIDDIR/api.pid"
printf "  %-12s building..." "api"
for _ in $(seq 1 30); do
  is_port_open "$PORT" && break
  sleep 1
done
if is_port_open "$PORT"; then
  printf " ready (hot-reload, port %s)\n" "$PORT"
else
  printf " FAILED\n" >&2
  echo "               Check log: cat $LOGDIR/aisets-api-dev.log" >&2
fi

if is_port_open "$VITE_PORT"; then
  printf "  %-12s already running (port %s)\n" "vite" "$VITE_PORT"
else
  if [ -z "$PNPM_BIN" ]; then
    echo "  vite         skipped: pnpm not found" >&2
  else
    if ! (cd /workspace/ui && CI=true "$PNPM_BIN" install --frozen-lockfile > "$LOGDIR/aisets-vite-deps.log" 2>&1); then
      printf "  %-12s failed to install deps (see %s/aisets-vite-deps.log)\n" "vite" "$LOGDIR" >&2
    else
      (
        cd /workspace/ui
        nohup "$PNPM_BIN" exec vite --host 0.0.0.0 --port "$VITE_PORT" --strictPort > "$LOGDIR/aisets-vite-dev.log" 2>&1 &
        echo $! > "$PIDDIR/vite.pid"
      )
      for _ in $(seq 1 20); do
        is_port_open "$VITE_PORT" && break
        sleep 0.5
      done
      if is_port_open "$VITE_PORT"; then
        printf "  %-12s started (port %s)\n" "vite" "$VITE_PORT"
      else
        printf "  %-12s failed to start (see %s/aisets-vite-dev.log)\n" "vite" "$LOGDIR" >&2
      fi
    fi
  fi
fi

URL="http://127.0.0.1:$VITE_PORT"
open_ui "$URL"
echo "✓ Aisets: $URL"
